# Supabase Settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Admin Dashboard Password
ADMIN_PASSWORD=your_strong_password

# Toss Payments (Korea)
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# PayPal (Global)
PAYPAL_CLIENT_ID=...
PAYPAL_SECRET=...

# Admin Notification Channel (telegram | discord | slack)
ADMIN_NOTIFICATION_CHANNEL=telegram

# Telegram Bot (recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord Webhook
DISCORD_WEBHOOK_URL=

# Slack Webhook (optional fallback)
SLACK_WEBHOOK_URL=
